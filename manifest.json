{
  "name": "ChatSweep",
  "description": "Selectively delete ChatGPT conversations. Select and clean up your chat history with full control.",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": ["debugger"],
  "content_scripts": [
    {
      "js": ["./dist/content.js"],
      "css": ["styles.css"],
      "matches": [
        "https://chatgpt.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "../dist/background.js"
  }
}